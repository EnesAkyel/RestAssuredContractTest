{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["info", "results"],
  "properties": {
    "info": {
      "type": "object",
      "required": ["count", "pages", "next", "prev"],
      "properties": {
        "count": {"type": "integer"},
        "pages": {"type": "integer"},
        "next": {"type": ["string", "null"]},
        "prev": {"type": ["string", "null"]}
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "status", "species", "type", "gender", "origin", "location", "image", "episode", "url", "created"],
        "properties": {
          "id": {"type": "integer"},
          "name": {"type": "string"},
          "status": {"type": "string"},
          "species": {"type": "string"},
          "type": {"type": "string"},
          "gender": {"type": "string"},
          "origin": {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": {"type": "string"},
              "url": {"type": "string"}
            }
          },
          "location": {
            "type": "object",
            "required": ["name", "url"],
            "properties": {
              "name": {"type": "string"},
              "url": {"type": "string"}
            }
          },
          "image": {"type": "string"},
          "episode": {
            "type": "array",
            "items": {"type": "string"}
          },
          "url": {"type": "string"},
          "created": {"type": "string", "format": "date-time"}
        }
      }
    }
  }
}