{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "type", "dimension", "residents", "url", "created"],
    "properties": {
      "id": {"type": "integer"},
      "name": {"type": "string"},
      "type": {"type": "string"},
      "dimension": {"type": "string"},
      "residents": {
        "type": "array",
        "items": {"type": "string"}
      },
      "url": {"type": "string"},
      "created": {"type": "string", "format": "date-time"}
    }
  }
}