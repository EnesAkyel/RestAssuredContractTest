{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "name", "air_date", "episode", "characters", "url", "created"],
    "properties": {
      "id": {"type": "integer"},
      "name": {"type": "string"},
      "air_date": {"type": "string"},
      "episode": {"type": "string"},
      "characters": {
        "type": "array",
        "items": {"type": "string"}
      },
      "url": {"type": "string"},
      "created": {"type": "string", "format": "date-time"}
    }
  }
}